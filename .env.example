# Langfuse (optional — demo runs without keys using in-memory spans)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM provider for live DSPy runs (offline mode ignores these)
LLM_PROVIDER=offline
ENTERPRISE_MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# DSPy
DSPY_CACHE_DIR=.cache/dspy

# Demo defaults
ENTERPRISE_FILING_ID=acme_corp_10k
